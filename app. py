import tkinter as tk
import random

# ---------------- المراحل ----------------
levels = [
    {
        "name": "المبتدئ",
        "cols": 4,
        "time": 40,
        "attempts": 20,
        "emojis": ['🍎','🍌','🍇','🍓','🥑','🥕','🍉','🥝']
    },
    {
        "name": "المحترف",
        "cols": 4,
        "time": 50,
        "attempts": 25,
        "emojis": ['🐶','🐱','🐰','🦊','🐻','🐼','🐨','🐯','🦁','🐸']
    },
    {
        "name": "الخبير",
        "cols": 5,
        "time": 60,
        "attempts": 30,
        "emojis": ['🚗','✈️','🚢','🚲','🚀','🚁','🚜','🏍️','🚌','🚤']
    },
    {
        "name": "النهائية",
        "cols": 6,
        "time": 70,
        "attempts": 35,
        "emojis": ['💎','👑','⚔️','🛡️','🏰','🗡️','📜','🔮','⚡','💰','🌟','🎯']
    }
]

# ---------------- المتغيرات ----------------

current_level = 0
buttons = []
cards = []

first_card = None
second_card = None

matched_pairs = 0
attempts = 0
time_left = 0

game_started = False

# ---------------- الواجهة ----------------

root = tk.Tk()
root.title("لعبة تحدي الذاكرة")
root.geometry("700x700")

info_label = tk.Label(root, font=("Arial", 14))
info_label.pack(pady=10)

status_label = tk.Label(root, font=("Arial", 12))
status_label.pack()

frame = tk.Frame(root)
frame.pack()

message_label = tk.Label(root, font=("Arial", 14))
message_label.pack(pady=10)


# ---------------- تحديث المعلومات ----------------

def update_info():
    level_name = levels[current_level]["name"]

    info_label.config(
        text=f"المرحلة: {current_level+1} - {level_name}   |   الزمن: {time_left}   |   المحاولات: {attempts}"
    )


# ---------------- المؤقت ----------------

def timer():
    global time_left

    if not game_started:
        return

    if time_left > 0:
        time_left -= 1
        update_info()
        root.after(1000, timer)

    else:
        lose_game()


# ---------------- بدء المرحلة ----------------

def start_level():
    global buttons
    global cards
    global attempts
    global time_left
    global matched_pairs
    global game_started
    global first_card
    global second_card

    for widget in frame.winfo_children():
        widget.destroy()

    buttons = []
    matched_pairs = 0

    level = levels[current_level]

    attempts = level["attempts"]
    time_left = level["time"]

    first_card = None
    second_card = None

    emojis = level["emojis"] * 2
    random.shuffle(emojis)
    cards = emojis

    cols = level["cols"]

    for i, emoji in enumerate(cards):

        btn = tk.Button(
            frame,
            text=emoji,
            width=6,
            height=3,
            font=("Arial", 16)
        )

        row = i // cols
        col = i % cols

        btn.grid(row=row, column=col, padx=5, pady=5)

        buttons.append(btn)

    update_info()

    status_label.config(
        text="احفظ أماكن الكروت لمدة 3 ثوانٍ"
    )

    game_started = False

    root.after(3000, hide_cards)


# ---------------- إخفاء الكروت ----------------

def hide_cards():
    global game_started

    for btn in buttons:
        btn.config(text="?", command=lambda b=btn: flip_card(b))

    status_label.config(text="ابدأ اللعب!")

    game_started = True
    timer()


# ---------------- قلب الكرت ----------------

def flip_card(button):
    global first_card
    global second_card
    global attempts

    if button["text"] != "?":
        return

    index = buttons.index(button)

    button.config(text=cards[index])

    if first_card is None:
        first_card = button
        return

    second_card = button

    attempts -= 1
    update_info()

    root.after(500, check_match)


# ---------------- فحص التطابق ----------------

def check_match():
    global matched_pairs
    global first_card
    global second_card

    if first_card is None or second_card is None:
        return

    idx1 = buttons.index(first_card)
    idx2 = buttons.index(second_card)

    if cards[idx1] == cards[idx2]:

        first_card.config(state="disabled")
        second_card.config(state="disabled")

        matched_pairs += 1

        if matched_pairs == len(levels[current_level]["emojis"]):
            win_level()

    else:
        first_card.config(text="?")
        second_card.config(text="?")

    first_card = None
    second_card = None

    if attempts <= 0:
        lose_game()


# ---------------- الفوز ----------------

def win_level():
    global current_level

    if current_level < len(levels) - 1:

        message_label.config(
            text="مبروك! الانتقال للمرحلة التالية"
        )

        current_level += 1

        root.after(2000, start_level)

    else:
        message_label.config(
            text="أنتِ أسطورة الذاكرة 👑"
        )


# ---------------- الخسارة ----------------

def lose_game():
    message_label.config(
        text="خسرتِ! حاولي مرة أخرى."
    )


# ---------------- زر إعادة اللعب ----------------

def restart():
    global current_level
    current_level = 0
    message_label.config(text="")
    start_level()


restart_button = tk.Button(
    root,
    text="إعادة اللعب",
    command=restart,
    font=("Arial", 12)
)

restart_button.pack(pady=10)


# ---------------- تشغيل اللعبة ----------------

start_level()
root.mainloop()
